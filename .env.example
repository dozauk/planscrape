# Resend API key — get one free at https://resend.com
RESEND_API_KEY=xxxxxxxxxxxxxxxx

# Where to send the digest
EMAIL_TO=doza@doza.org

# The "from" address — must be a verified domain in your Resend account
EMAIL_FROM=onboarding@resend.dev

# Optional: AI classification of planning applications (Anthropic API)
# Without these, all applications are stored unclassified (priority = null)
# and all applications appear in the digest.
ANTHROPIC_API_KEY=sk-ant-xxxx

# Classification prompt — two ways to provide it:
#
# Local development: put the prompt in a plain text file (gitignored) and set:
CLASSIFICATION_PROMPT_FILE=./prompt.txt
#
# GitHub Actions: set CLASSIFICATION_PROMPT as a repository secret (multiline supported).
# The file-based option takes precedence if both are set.
