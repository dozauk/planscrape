# Resend API key — get one free at https://resend.com
RESEND_API_KEY=xxxxxxxxxxxxxxxx

# Where to send the digest
EMAIL_TO=doza@doza.org

# The "from" address — must be a verified domain in your Resend account
EMAIL_FROM=onboarding@resend.dev

# Optional: AI classification of planning applications (Anthropic API)
# Without these, all applications are stored unclassified (priority = null)
# and all applications appear in the digest.
ANTHROPIC_API_KEY=sk-ant-xxxx

# The classification prompt template — use {{ref}}, {{council}}, {{description}} as placeholders.
# This is intentionally kept as a secret so the business purpose is not visible in public code.
# For GitHub Actions deployment, set CLASSIFICATION_PROMPT as a repository secret.
# For local development, paste the full prompt on a single line (use \n for newlines if needed),
# or export it in your shell before running: export CLASSIFICATION_PROMPT="$(cat prompt.txt)"
CLASSIFICATION_PROMPT=
